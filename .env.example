# ===========================================
# PiZoW - Environment Configuration
# ===========================================
# Copy this file to .env and update values
# cp .env.example .env
# ===========================================

# ----- Pi Connection -----
PI_USER=your_username
PI_HOST=192.168.1.100
PI_PORT=22
PI_PASSWORD=your_pi_password

# ----- Project Settings -----
PROJECT_NAME=myapp
PROJECT_PATH=/home/your_username/myapp
LOCAL_PATH=/path/to/local/project      # absolute path to your local project folder
REPO_URL=git@github.com:your_username/your_repo.git  # used with --remote
BRANCH=main

# ----- App Settings -----
NODE_ENV=production
PORT=3000

# ----- PM2 Settings -----
PM2_APP_NAME=myapp
PM2_INSTANCES=1

# ----- Nginx Settings -----
DOMAIN=myapp.local
ENABLE_SSL=false

# ----- Optional: Database -----
# DATABASE_URL=postgresql://user:pass@localhost:5432/db
# REDIS_URL=redis://localhost:6379

# ----- Optional: API Keys -----
# API_KEY=your_api_key_here
# SECRET_KEY=your_secret_key_here
